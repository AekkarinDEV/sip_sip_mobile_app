<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Back -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="56dp"
            android:text="← กลับ"
            android:textColor="#000000"
            android:textSize="18sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="กรอกข้อมูลที่จำเป็น"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ================= CARD ================= -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardForm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="8dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="12dp"
            app:cardUseCompatPadding="true"
            app:cardBackgroundColor="@android:color/white"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="25dp">

                <!-- Section -->
                <TextView
                    android:id="@+id/tvSectionBody"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ข้อมูลทางกายภาพ"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <!-- Gender dropdown -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilGender"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    app:endIconMode="dropdown_menu"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:layout_constraintTop_toBottomOf="@id/tvSectionBody"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <AutoCompleteTextView
                        android:id="@+id/etGender"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="เพศ"
                        android:inputType="none"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Weight -->
                <EditText
                    android:id="@+id/etWeight"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/edittext_bg"
                    android:hint="น้ำหนัก (กก.)"
                    android:inputType="number"
                    app:layout_constraintTop_toBottomOf="@id/tilGender"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- Activity dropdown -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilActivity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    app:endIconMode="dropdown_menu"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:layout_constraintTop_toBottomOf="@id/etWeight"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <AutoCompleteTextView
                        android:id="@+id/etActivity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="ออกกำลังกายที่ทำประจำ"
                        android:inputType="none"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Divider -->
                <View
                    android:id="@+id/divider1"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="#E0E0E0"
                    app:layout_constraintTop_toBottomOf="@id/tilActivity"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- Notify -->

                <TextView
                    android:id="@+id/tvNotify"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="การแจ้งเตือน"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/divider1" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchNotify"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="เปิดการแจ้งเตือน"
                    app:layout_constraintTop_toBottomOf="@id/tvNotify"
                    app:layout_constraintStart_toStartOf="parent"/>

                <!-- Divider -->
                <View
                    android:id="@+id/divider2"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="#E0E0E0"
                    app:layout_constraintTop_toBottomOf="@id/switchNotify"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- ===== TIME ===== -->

                <!-- หัวข้อ -->
                <TextView
                    android:id="@+id/tvTimeTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="เวลา"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/divider2"
                    app:layout_constraintStart_toStartOf="parent"/>

                <!-- label เวลาตื่น -->
                <TextView
                    android:id="@+id/tvWakeTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="เวลาตื่นนอน"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/tvTimeTitle"
                    app:layout_constraintStart_toStartOf="parent"/>

                <!-- เวลาตื่น -->
                <EditText
                    android:id="@+id/etStartTime"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/edittext_bg"
                    android:hint="08:00"
                    android:focusable="false"
                    android:clickable="true"
                    app:layout_constraintTop_toBottomOf="@id/tvWakeTime"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/etEndTime"
                    app:layout_constraintWidth_percent="0.45"/>

                <!-- label เวลานอน -->
                <TextView
                    android:id="@+id/tvSleepTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="เวลานอน"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/tvTimeTitle"
                    app:layout_constraintStart_toStartOf="@id/etEndTime"/>

                <!-- เวลานอน -->
                <EditText
                    android:id="@+id/etEndTime"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/edittext_bg"
                    android:hint="22:00"
                    android:focusable="false"
                    android:clickable="true"
                    app:layout_constraintTop_toBottomOf="@id/tvSleepTime"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintWidth_percent="0.45"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>
        <!-- ===== STEP INDICATOR ===== -->
        <LinearLayout
            android:id="@+id/stepIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/cardForm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Step 1 (ปัจจุบัน) -->
            <View
                android:layout_width="28dp"
                android:layout_height="6dp"
                android:background="@drawable/step_active"/>

            <View
                android:layout_width="8dp"
                android:layout_height="1dp"/>

            <!-- Step 2 -->
            <View
                android:layout_width="28dp"
                android:layout_height="6dp"
                android:background="@drawable/step_inactive"/>

            <View
                android:layout_width="8dp"
                android:layout_height="1dp"/>



        </LinearLayout>
        <!-- Confirm -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirm"
            android:layout_width="294dp"
            android:layout_height="48dp"
            android:layout_marginTop="50dp"
            android:text="ยืนยัน"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="#5FACE0"
            app:cornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/cardForm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
